# Supabase (Expo loads EXPO_PUBLIC_* at build time). Use Project API keys → Publishable key.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Optional: pin Edge Functions region (e.g. eu-west-1, us-east-1) if invoke relay/network routing is flaky.
# EXPO_PUBLIC_SUPABASE_FUNCTIONS_REGION=eu-west-1

# LiveKit is NOT configured in the Expo app: the Edge Function `livekit-token` returns { token, url }.
# Set these as Supabase secrets for that function:
#   LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
#   LIVEKIT_API_KEY=...
#   LIVEKIT_API_SECRET=...
# Optional: LIVEKIT_SKIP_AGENT_DISPATCH=true (if you dispatch agents only via LiveKit dashboard rules)
# Optional: LIVEKIT_AGENT_NAME=translator-agent (must match translator-agent worker registration)

# Dev-only: verbose LiveKit client logs in Metro (`EXPO_PUBLIC_VOISA_VERBOSE_LK=1`).
# Dev-only: show `lk.transcription` fallback row in Translate screen (`EXPO_PUBLIC_VOISA_DEBUG_LK_CAPTIONS=1`, __DEV__ only).
# EXPO_PUBLIC_VOISA_VERBOSE_LK=1
# EXPO_PUBLIC_VOISA_DEBUG_LK_CAPTIONS=1

# Translator worker (`translator-agent/.env.local`) additionally needs SONIOX_API_KEY — see translator-agent/.env.example.
