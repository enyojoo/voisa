# LiveKit project (same values as LiveKit Cloud dashboard → Settings → Keys)
LIVEKIT_URL=wss://your_livekit_url
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Agent joins room via rtc-node WebRTC — transient ICE timeouts (`wait_pc_connection`) happen on flaky paths.
# Retries ctx.connect() with exponential backoff (defaults: 4 attempts, 750ms base delay).
# LIVEKIT_AGENT_CONNECT_ATTEMPTS=4
# LIVEKIT_AGENT_CONNECT_BASE_DELAY_MS=750

# Soniox console API key — STT + two-way translation run against Soniox WebSockets directly from this worker.
SONIOX_API_KEY=your_soniox_api_key

# Processing region for default STT/TTS WebSocket hosts (must match your Soniox project region).
# https://soniox.com/docs/data-residency#regional-endpoints
# SONIOX_REGION=us
# SONIOX_REGION=eu
# SONIOX_REGION=jp

# Override STT / TTS websocket URLs explicitly (optional). When unset, URLs derive from SONIOX_REGION.
# SONIOX_BASE_URL=wss://stt-rt.eu.soniox.com/transcribe-websocket
# SONIOX_TTS_WS_URL=wss://tts-rt.eu.soniox.com/tts-websocket

# LiveKit Agents: sync user/agent captions to audio playback vs send as soon as available.
# https://docs.livekit.io/agents/multimodality/text/
# VOISA_SYNC_TRANSCRIPTION=true

# Optional Soniox STT session `context` / glossary (https://soniox.com/docs/api-reference/stt/websocket-api)
# SONIOX_CONTEXT_JSON={"general":[{"key":"domain","value":"Healthcare"}]}
# SONIOX_CONTEXT_GENERAL_JSON=[{"key":"topic","value":"Diabetes"}]
# SONIOX_CONTEXT_TEXT=...
# SONIOX_CONTEXT_TERMS_JSON=["Celebrex","Zyrtec"]
# SONIOX_TRANSLATION_TERMS_JSON=[{"source":"Mr. Smith","target":"Sr. Smith"}]

# If TLS to Soniox fails with ECONNRESET / "socket disconnected before secure TLS connection was established":
# omit or use ipv4first (default via code) vs verbatim — see SONIOX_STT_DNS_RESULT_ORDER below.
# SONIOX_WS_HANDSHAKE_TIMEOUT_MS=20000
# SONIOX_STT_DNS_RESULT_ORDER=verbatim

# Default translation pair until the mobile client connects (Soniox two_way; ISO codes).
# The Expo app sends {"type":"voisa.language_pair","languageA","languageB"} over LiveKit Data —
# optional: translationDomain (string), translationTerms ([{source,target}]) for Soniox context.
# that replaces these for the session. Any two different languages from soniox_language_allowlist.ts work.
TRANSLATION_LANGUAGE_A=en
TRANSLATION_LANGUAGE_B=es

# Soniox endpointing: max ms to wait after speech energy drops before Soniox closes an utterance.
# Lower (400–700): shorter waits, snappier commits, more phrase fragments.
# Higher (900–1500): longer waits, fuller clauses/sentences, slightly slower finals & TTS start.
SONIOX_MAX_ENDPOINT_DELAY_MS=700

# Voisa-specific: ms of quiet after last streamed translation tokens before we flush the utterance (bridge final + TTS).
# Lower (250–450): faster spoken replies; may split mid-thought if you pause briefly.
# Higher (550–900): merges hesitant pauses into one spoken reply; adds latency before translation plays.
TRANSCRIPT_FINALIZE_QUIET_MS=450

# Text-to-speech: soniox (default — Soniox realtime WebSocket) or livekit (Cartesia via LiveKit Inference).
# A/B if Soniox path shows crackling: try livekit for different encoder / latency profile.
VOISA_TTS_PROVIDER=soniox

# --- Interpretation TTS chunking (VoisaInterpretationCoordinator) ---
# Larger min chunk = fewer chunk seams (less boundary crackle) but slower first syllable.
# Defaults (if unset): min 44, max 140, debounce 260ms — fewer `say()` boundaries + serialized playout (no concurrent TTS).
# VOISA_TTS_MIN_CHUNK_CHARS=44
# VOISA_TTS_MAX_CHUNK_CHARS=140
# VOISA_TTS_DEBOUNCE_MS=260

# Partial `voisa.transcript` coalesce before publishData (20–500 ms). Higher = fewer packets, choppier UI text.
# VOISA_TRANSCRIPT_BRIDGE_COALESCE_MS=55

# Debug: `1` enables noisy per-partial bridge logs (default off for production).
# VOISA_DEBUG_TRANSCRIPT_BRIDGE=0
# Log each coordinator `say` enqueue (chunk tail).
# VOISA_DEBUG_TTS_QUEUE=0
# Cap `say()` calls per internal pump pass (1–5). Lower = fewer concurrent Soniox streams / less mux contention.
# VOISA_TTS_MAX_SAYS_PER_PUMP=3
# Chunk mode: debounce flush only if buffered tail is at least this long (avoids instant micro-speak).
# VOISA_TTS_DEBOUNCE_FLUSH_MIN_CHARS=28
# Stream mode (default on): wait for this many translated chars before first enqueue in an utterance (0 = off).
# VOISA_TTS_STREAM_MIN_CHARS=8
# Rewrite guard: clears in-flight translation TTS only on **final** `voisa.transcript` (interim jitter never cuts playout).
# VOISA_ASR_REWRITE_STRICT=1 clears TTS whenever finalized original is not a prefix extension vs the prior finalized draft (harsh).
# VOISA_ASR_REWRITE_STRICT=0
# With lenient + finals, compare common prefix vs prior draft — clear TTS below this threshold (default 6).
# VOISA_ASR_REWRITE_MIN_COMMON_CHARS=6
# Structured TTS/STT/VAD metrics for correlating audible crackle with `ttfbMs` / `audioDurationMs`.
# VOISA_CRACK_DIAGNOSE=0
# One `say(ReadableStream<string>)` per utterance — continuous readout while partials grow (default on). Set 0 for chunk mode.
# VOISA_TTS_USE_TEXT_STREAM=1
# Log Soniox TTS sample rate / format at agent start (Soniox provider only).
# VOISA_DEBUG_AUDIO=0
# Subtle PCM fade on each Soniox stream (ms, 0 = off that edge). Reduces abrupt clip starts/ends on the agent track.
# VOISA_TTS_FADE_IN_MS=8
# VOISA_TTS_FADE_OUT_MS=10
# Worker log `inference is slower than realtime` is from Silero VAD (`@livekit/agents-plugin-silero`), not Soniox TTS.

# Soniox realtime TTS — uses SONIOX_API_KEY. Docs: https://soniox.com/docs/tts/rt/real-time-generation · quotas https://soniox.com/docs/tts/rt/limits-and-quotas
# SONIOX_TTS_MODEL=tts-rt-v1
# Optional: pin one Studio voice for every locale — https://soniox.com/docs/tts/concepts/voices
# Omit to let translator-agent choose a curated voice per `voisa.language_pair` languageB (`src/soniox_tts_voice_defaults.ts`).
# SONIOX_TTS_VOICE=Adrian
# If unset, TTS language defaults from TRANSLATION_LANGUAGE_B; app updates via voisa.language_pair (languageB).
# SONIOX_TTS_LANGUAGE=en
# SONIOX_TTS_SAMPLE_RATE=24000
# SONIOX_TTS_AUDIO_FORMAT=pcm_s16le
# Codec bitrate (compressed formats only; omit for pcm_s16le — Soniox returns 400 if set with PCM).
# SONIOX_TTS_BITRATE=128000
# SONIOX_TTS_WS_URL=wss://tts-rt.soniox.com/tts-websocket
# Whole-connection idle ping interval (ms); Soniox recommends ~20–30s — https://soniox.com/docs/tts/rt/connection-keepalive
# SONIOX_TTS_KEEPALIVE_INTERVAL_MS=25000
